{
  "name": "claude-knowledge",
  "version": "0.1.0",
  "private": true,
  "description": "LLM-powered personal knowledge base (wiki) system — ingest, compile, query, and visualize knowledge",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.121",
    "@anthropic-ai/sdk": "^0.91.1",
    "commander": "^14.0.3",
    "gray-matter": "^4.0.3"
  }
}
