# Claude Knowledge 环境变量配置
# 复制此文件为 .env 并根据需要修改:
#   cp .env.example .env

# 【必需】Anthropic API 密钥（或兼容接口的密钥）
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# 【可选】自定义 API 地址（兼容 Anthropic 接口的第三方服务）
# ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic

# 【可选】指定模型名称
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# 【可选】Wiki 输出目录（默认 ./wiki）
# WIKI_DIR=./wiki

# 【可选】原始文档目录（默认 ./raw）
# RAW_DIR=./raw

# 【可选】搜索 Web UI 端口（默认 3456）
# SEARCH_PORT=3456
